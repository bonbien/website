---
import { Container } from '@components/odyssey-theme';
import Layout from '../../layouts/Page.astro';
import { useTranslations } from '../../i18n/utils';

const t = useTranslations('vi');

const seo = {
	title: t('seo.title'),
	description: t('seo.description'),
};
---

<Layout seo={seo}>
	<!-- Hero Section - Full Screen -->
	<section class="hero">
		<div class="hero__bg">
			<img src="/outside.png" alt="Bốn Biển" />
		</div>
		<div class="hero__content">
			<h1 class="hero__title">{t('hero.title')}</h1>
			<p class="hero__subtitle">{t('hero.subtitle')}</p>
		</div>
	</section>

	<!-- About Section -->
	<section class="about">
		<Container>
			<div class="about__content scroll-animate">
				<h2 class="section-title center">{t('about.title')}</h2>
				<div class="about__text">
					<p>{t('about.text1')}</p>
					<p>{t('about.text2')}</p>
				</div>
			</div>
			<div class="about__images">
				<div class="about__image scroll-animate">
					<img src="/kichen.png" alt="Kitchen" />
				</div>
				<div class="about__image scroll-animate">
					<img src="/green.png" alt="Fresh ingredients" />
				</div>
			</div>
		</Container>
	</section>

	<!-- Features -->
	<section class="features">
		<Container>
			<div class="features__grid">
				<div class="feature scroll-animate">
					<h3 class="feature__title">{t('feature.fresh')}</h3>
					<p class="feature__desc">{t('feature.fresh.desc')}</p>
				</div>
				<div class="feature scroll-animate">
					<h3 class="feature__title">{t('feature.traditional')}</h3>
					<p class="feature__desc">{t('feature.traditional.desc')}</p>
				</div>
				<div class="feature scroll-animate">
					<h3 class="feature__title">{t('feature.view')}</h3>
					<p class="feature__desc">{t('feature.view.desc')}</p>
				</div>
			</div>
		</Container>
	</section>

	<!-- Menu Showcase -->
	<section class="menu">
		<Container>
			<h2 class="section-title center scroll-animate">{t('menu.title')}</h2>

			<div class="menu__item scroll-animate">
				<div class="menu__image">
					<img src="/lobster.png" alt={t('menu.lobster')} />
				</div>
				<div class="menu__info">
					<h3 class="menu__name">{t('menu.lobster')}</h3>
					<p class="menu__description">{t('menu.lobster.desc')}</p>
				</div>
			</div>

			<div class="menu__item menu__item--reverse scroll-animate">
				<div class="menu__image">
					<img src="/razor-clams.png" alt={t('menu.clams')} />
				</div>
				<div class="menu__info">
					<h3 class="menu__name">{t('menu.clams')}</h3>
					<p class="menu__description">{t('menu.clams.desc')}</p>
				</div>
			</div>

			<div class="menu__item scroll-animate">
				<div class="menu__image">
					<img src="/sashimi.png" alt={t('menu.sashimi')} />
				</div>
				<div class="menu__info">
					<h3 class="menu__name">{t('menu.sashimi')}</h3>
					<p class="menu__description">{t('menu.sashimi.desc')}</p>
				</div>
			</div>

			<div class="menu__item menu__item--reverse scroll-animate">
				<div class="menu__image">
					<img src="/dishes.png" alt={t('menu.platter')} />
				</div>
				<div class="menu__info">
					<h3 class="menu__name">{t('menu.platter')}</h3>
					<p class="menu__description">{t('menu.platter.desc')}</p>
				</div>
			</div>

			<div class="menu__cta">
				<a href="/menu" class="button">{t('menu.view')}</a>
			</div>
		</Container>
	</section>

	<!-- Location -->
	<section id="contact" class="location">
		<Container>
			<div class="location__wrapper">
				<div class="location__image scroll-animate">
					<img src="/interior.png" alt="Bốn Biển" />
				</div>
				<div class="location__content scroll-animate">
					<h2 class="section-title">{t('location.title')}</h2>

					<div class="location__details">
						<div class="detail">
							<h3 class="detail__label">{t('location.address')}</h3>
							<p class="detail__value">{t('location.address.value')}</p>
						</div>

						<div class="detail">
							<h3 class="detail__label">{t('location.hours')}</h3>
							<p class="detail__value">{t('location.hours.weekdays')}</p>
							<p class="detail__value">{t('location.hours.closed')}</p>
						</div>

						<div class="detail">
							<h3 class="detail__label">{t('location.contact')}</h3>
							<p class="detail__value"><a href="tel:+84">+84 (Reservation)</a></p>
							<p class="detail__value"><a href="mailto:info@bonbienseafood.com">info@bonbienseafood.com</a></p>
						</div>
					</div>
				</div>
			</div>
		</Container>
	</section>
</Layout>

<script>
	// Scroll animation with Intersection Observer
	const observerOptions = {
		threshold: 0.1,
		rootMargin: '0px 0px -50px 0px'
	};

	const observer = new IntersectionObserver((entries) => {
		entries.forEach((entry) => {
			if (entry.isIntersecting) {
				entry.target.classList.add('animate-in');
			}
		});
	}, observerOptions);

	// Observe all elements with scroll-animate class
	document.addEventListener('DOMContentLoaded', () => {
		const animateElements = document.querySelectorAll('.scroll-animate');
		animateElements.forEach((el) => observer.observe(el));
	});
</script>

<style>
	/* Scroll Animation Styles */
	.scroll-animate {
		opacity: 0;
		transform: translateY(40px);
		transition: opacity 0.8s ease, transform 0.8s ease;
	}

	.scroll-animate.animate-in {
		opacity: 1;
		transform: translateY(0);
	}

	/* Stagger animation delays */
	.feature.scroll-animate:nth-child(1) { transition-delay: 0.1s; }
	.feature.scroll-animate:nth-child(2) { transition-delay: 0.2s; }
	.feature.scroll-animate:nth-child(3) { transition-delay: 0.3s; }

	.about__image.scroll-animate:nth-child(1) { transition-delay: 0.1s; }
	.about__image.scroll-animate:nth-child(2) { transition-delay: 0.2s; }

	/* Hero Section - Dark Elegant Style */
	.hero {
		height: 100vh;
		min-height: 700px;
		display: flex;
		align-items: center;
		justify-content: center;
		position: relative;
		padding: 0 2rem;
		overflow: hidden;
	}

	.hero__bg {
		position: absolute;
		top: 0;
		left: 0;
		width: 100%;
		height: 100%;
		z-index: 0;
	}

	.hero__bg img {
		width: 100%;
		height: 100%;
		object-fit: cover;
		filter: brightness(0.4);
	}

	.hero__bg::after {
		content: '';
		position: absolute;
		top: 0;
		left: 0;
		width: 100%;
		height: 100%;
		background: linear-gradient(180deg, rgba(0,0,0,0.6) 0%, rgba(0,0,0,0.3) 50%, rgba(0,0,0,0.7) 100%);
	}

	.hero__content {
		text-align: center;
		max-width: 1000px;
		position: relative;
		z-index: 1;
	}

	.hero__title {
		font-size: clamp(3rem, 8vw, 6rem);
		font-weight: 300;
		letter-spacing: 0.02em;
		line-height: 1.1;
		margin-bottom: 1.5rem;
		color: var(--theme-on-bg);
	}

	.hero__subtitle {
		font-size: clamp(1.1rem, 2vw, 1.5rem);
		font-weight: 300;
		letter-spacing: 0.03em;
		line-height: 1.6;
		color: var(--theme-text-secondary);
	}

	/* Section Title */
	.section-title {
		font-size: clamp(2rem, 4vw, 3.5rem);
		font-weight: 400;
		letter-spacing: 0.01em;
		line-height: 1.2;
		margin-bottom: 3rem;
		color: var(--theme-on-bg);
	}

	.section-title.center {
		text-align: center;
	}

	/* About Section */
	.about {
		padding: 10rem 0;
		background: var(--theme-bg);
		position: relative;
		overflow: hidden;
	}

	.about::before {
		content: '';
		position: absolute;
		top: 0;
		left: 0;
		width: 100%;
		height: 100%;
		background-image: url('/kichen.png');
		background-size: cover;
		background-position: center;
		opacity: 0.05;
		pointer-events: none;
		z-index: 0;
	}

	.about > * {
		position: relative;
		z-index: 1;
	}

	.about__content {
		max-width: 900px;
		margin: 0 auto 6rem;
		text-align: center;
	}

	.about__text {
		max-width: 800px;
		margin: 0 auto;
	}

	.about__text p {
		font-size: clamp(1rem, 1.5vw, 1.2rem);
		line-height: 1.8;
		margin-bottom: 1.5rem;
		font-weight: 300;
		letter-spacing: 0.02em;
		color: var(--theme-text-secondary);
	}

	.about__images {
		display: grid;
		grid-template-columns: 1fr 1fr;
		gap: 3rem;
		max-width: 1400px;
		margin: 0 auto;
	}

	.about__image {
		width: 100%;
		height: 650px;
		overflow: hidden;
	}

	.about__image img {
		width: 100%;
		height: 100%;
		object-fit: cover;
		transition: transform 0.6s ease;
	}

	.about__image:hover img {
		transform: scale(1.05);
	}

	/* Features */
	.features {
		padding: 8rem 0;
		background: var(--theme-surface-1);
		position: relative;
	}

	.features::before {
		content: '';
		position: absolute;
		top: 0;
		left: 0;
		width: 100%;
		height: 100%;
		background-image: url('/candle.png');
		background-size: cover;
		background-position: center;
		opacity: 0.08;
		pointer-events: none;
	}

	.features__grid {
		display: grid;
		grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
		gap: 6rem;
		max-width: 1200px;
		margin: 0 auto;
	}

	.feature {
		text-align: left;
	}

	.feature__title {
		font-size: 0.9rem;
		font-weight: 500;
		margin-bottom: 1rem;
		letter-spacing: 0.15em;
		color: var(--theme-on-bg);
		text-transform: uppercase;
	}

	.feature__desc {
		font-size: clamp(1rem, 1.8vw, 1.2rem);
		line-height: 1.8;
		font-weight: 300;
		letter-spacing: 0.02em;
		color: var(--theme-text-secondary);
	}

	/* Menu Section */
	.menu {
		padding: 10rem 0;
		background: var(--theme-bg);
	}

	.menu__item {
		display: grid;
		grid-template-columns: 1fr 1fr;
		gap: 6rem;
		margin-bottom: 8rem;
		align-items: center;
	}

	.menu__item--reverse {
		direction: rtl;
	}

	.menu__item--reverse > * {
		direction: ltr;
	}

	.menu__image {
		width: 100%;
		height: 600px;
		overflow: hidden;
	}

	.menu__image img {
		width: 100%;
		height: 100%;
		object-fit: cover;
		transition: transform 0.6s cubic-bezier(0.4, 0, 0.2, 1);
	}

	.menu__item:hover .menu__image img {
		transform: scale(1.05);
	}

	.menu__info {
		padding: 2rem 0;
	}

	.menu__name {
		font-size: clamp(1.5rem, 3vw, 2rem);
		font-weight: 400;
		letter-spacing: 0.01em;
		margin-bottom: 1.5rem;
		color: var(--theme-on-bg);
	}

	.menu__description {
		font-size: clamp(1rem, 1.5vw, 1.1rem);
		line-height: 1.7;
		font-weight: 300;
		letter-spacing: 0.02em;
		color: var(--theme-text-secondary);
	}

	.menu__cta {
		text-align: center;
		margin-top: 6rem;
	}

	/* Button */
	.button {
		display: inline-block;
		padding: 1.5rem 4rem;
		font-size: 1rem;
		font-weight: 400;
		letter-spacing: 0.1em;
		text-transform: uppercase;
		text-decoration: none;
		color: #000000;
		background: #ffffff;
		border: 1px solid #ffffff;
		transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
	}

	.button:hover {
		background: transparent;
		color: #ffffff;
		border-color: #ffffff;
	}

	/* Location Section */
	.location {
		padding: 10rem 0;
		background: var(--theme-surface-1);
	}

	.location__wrapper {
		display: grid;
		grid-template-columns: 1.2fr 1fr;
		gap: 6rem;
		align-items: center;
	}

	.location__image {
		width: 100%;
		height: 700px;
		overflow: hidden;
	}

	.location__image img {
		width: 100%;
		height: 100%;
		object-fit: cover;
	}

	.location__content {
		padding: 2rem 0;
	}

	.location__details {
		display: flex;
		flex-direction: column;
		gap: 3rem;
	}

	.detail__label {
		font-size: 0.85rem;
		font-weight: 500;
		letter-spacing: 0.15em;
		text-transform: uppercase;
		margin-bottom: 1rem;
		color: var(--theme-text-tertiary);
	}

	.detail__value {
		font-size: clamp(1rem, 1.8vw, 1.2rem);
		line-height: 1.7;
		font-weight: 300;
		letter-spacing: 0.01em;
		color: var(--theme-on-bg);
		margin-bottom: 0.5rem;
	}

	.detail__value a {
		color: var(--theme-on-bg);
		text-decoration: none;
		transition: opacity 0.2s ease;
	}

	.detail__value a:hover {
		color: var(--theme-text-secondary);
	}

	/* Responsive */
	@media (max-width: 968px) {
		.hero {
			min-height: 600px;
		}

		.about__images {
			grid-template-columns: 1fr;
			gap: 2rem;
		}

		.about__image {
			height: 350px;
		}

		.about,
		.menu,
		.location {
			padding: 6rem 0;
		}

		.features {
			padding: 5rem 0;
		}

		.features__grid {
			grid-template-columns: 1fr;
			gap: 4rem;
		}

		.menu__item,
		.menu__item--reverse {
			grid-template-columns: 1fr;
			gap: 3rem;
			margin-bottom: 5rem;
			direction: ltr;
		}

		.menu__image {
			height: 400px;
		}

		.location__wrapper {
			grid-template-columns: 1fr;
			gap: 4rem;
		}

		.location__image {
			height: 400px;
		}
	}

	@media (max-width: 640px) {
		.hero {
			min-height: 500px;
		}

		.about,
		.menu,
		.location {
			padding: 4rem 0;
		}

		.features {
			padding: 3rem 0;
		}

		.section-title {
			margin-bottom: 3rem;
		}

		.menu__image,
		.location__image {
			height: 300px;
		}
	}
</style>
